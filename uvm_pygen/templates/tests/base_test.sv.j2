//------------------------------------------------------------------------------
// Class: {{ name }}_base_test
// Description: Base test – retrieves the virtual interface from resource_db
//              (set by top.sv) and creates the environment.
//              All tests extend from this.
//------------------------------------------------------------------------------

class {{ name }}_base_test extends uvm_test;
    `uvm_component_utils({{ name }}_base_test)

    //--------------------------------------------------------------------------
    // Environment handle
    //--------------------------------------------------------------------------
    {{ env_name }} m_env;

    //--------------------------------------------------------------------------
    // Virtual interface handle
    //--------------------------------------------------------------------------
    {% if if_name %}
    virtual {{ if_name }} m_vif;
    {% endif %}

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name = "{{ name }}_base_test", uvm_component parent = null);
        super.new(name, parent);
    endfunction : new

    //--------------------------------------------------------------------------
    // Build Phase – retrieve vif from resource_db, create env
    //--------------------------------------------------------------------------
    virtual function void build_phase(uvm_phase phase);
        super.build_phase(phase);

        {% if if_name %}
        // Retrieve virtual interface set by top.sv via uvm_resource_db.
        // Two-step get_by_name + .read() is used for UVM 1.1d compatibility —
        // read_by_name has a type-resolution bug with virtual interfaces in
        // some simulators (Questa mtiUvm).
        begin
            uvm_resource #(virtual {{ if_name }}) vif_res;
            vif_res = uvm_resource_db #(virtual {{ if_name }})::get_by_name("*", "vif", 0);
            if (vif_res == null)
                `uvm_fatal(get_type_name(), "Failed to get virtual interface '{{ if_name }}' from resource_db")
            m_vif = vif_res.read(this);
        end
        {% endif %}

        // Create the environment using the UVM factory
        m_env = {{ env_name }}::type_id::create("m_env", this);

        `uvm_info(get_type_name(), "Build phase complete.", UVM_HIGH)
    endfunction : build_phase

    //--------------------------------------------------------------------------
    // Start of Simulation Phase – report test identity
    //--------------------------------------------------------------------------
    virtual function void start_of_simulation_phase(uvm_phase phase);
        super.start_of_simulation_phase(phase);
        `uvm_info(get_type_name(), $sformatf("Running test: %s", get_type_name()), UVM_LOW)
    endfunction : start_of_simulation_phase

    // Note: No run_phase here.
    // The base test only builds the testbench; child tests define run_phase.

endclass : {{ name }}_base_test

//------------------------------------------------------------------------------
// Class: {{ agent.name }}_driver
// Description: Driver for {{ agent.name }}
//------------------------------------------------------------------------------

class {{ agent.name }}_driver extends uvm_driver #({{ trans_type }});
    `uvm_component_utils({{ agent.name }}_driver)

    //--------------------------------------------------------------------------
    // Virtual interface handle
    //--------------------------------------------------------------------------
    virtual {{ if_name }} vif;

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    //--------------------------------------------------------------------------
    // Build Phase – retrieve vif from resource_db
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        uvm_resource #(virtual {{ if_name }}) vif_res;
        super.build_phase(phase);

        vif_res = uvm_resource_db #(virtual {{ if_name }})::get_by_name("*", "vif", 0);
        if (vif_res == null)
            `uvm_fatal("NOVIF", {"Virtual interface not found in resource_db for: ", get_full_name()})
        vif = vif_res.read(this);
    endfunction

    //--------------------------------------------------------------------------
    // Run Phase – fetch items from sequencer and drive them
    //--------------------------------------------------------------------------
    task run_phase(uvm_phase phase);
        forever begin
            seq_item_port.get_next_item(req);
            drive_item(req);
            seq_item_port.item_done();
        end
    endtask

    //--------------------------------------------------------------------------
    // Drive Item – uses the interface drive() task defined in {{ if_name }}
    //--------------------------------------------------------------------------
    virtual task drive_item({{ trans_type }} item);
        vif.drive(item);
    endtask

endclass : {{ agent.name }}_driver

//------------------------------------------------------------------------------
// Class: {{ refmodel_name }}
// Description: Reference model as a uvm_subscriber.
//              Receives input transaction, computes expected output,
//              and broadcasts the predicted result.
//------------------------------------------------------------------------------

class {{ refmodel_name }} extends uvm_subscriber #({{ trans_type }});
    `uvm_component_utils({{ refmodel_name }})

    // Analysis port for expected output (connected to scoreboard)
    uvm_analysis_port #({{ trans_type }}) ap_expected;

    // Constructor
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    // Build phase – create analysis port
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);
        ap_expected = new("ap_expected", this);
    endfunction

    // Write method – called when a transaction arrives on the export
    function void write({{ trans_type }} t);
        {{ trans_type }} expected;
        expected = {{ trans_type }}::type_id::create("expected");
        predict(t, expected);
        ap_expected.write(expected);
    endfunction

    // -----------------------------------------------------------------------
    // Placeholder prediction logic – override in your extended class
    // or edit this method directly.
    // -----------------------------------------------------------------------
    virtual function void predict({{ trans_type }} inp, {{ trans_type }} outp);
        // Copy input fields
        {% for var in trans.variables if var.direction.value == 'input' %}
        outp.{{ var.name }} = inp.{{ var.name }};
        {% endfor %}

        // *** PREDICTION LOGIC GOES HERE ***
        // Output fields to populate:
        {% for var in trans.variables if var.direction.value == 'output' %}
        // outp.{{ var.name }} = ...;
        {% endfor %}
    endfunction

endclass
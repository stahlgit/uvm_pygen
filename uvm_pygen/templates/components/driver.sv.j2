//------------------------------------------------------------------------------
// Class: {{ agent.name }}_driver
// Description: Driver for {{ agent.name }}
//------------------------------------------------------------------------------

class {{ agent.name }}_driver extends uvm_driver #({{ trans_type }});
    `uvm_component_utils({{ agent.name }}_driver)

    // Virtual Interface
    virtual {{ if_name }} vif;

    // Constructor
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    // Build Phase
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);
        // Get interface from config_db
        if(!uvm_config_db#(virtual {{ if_name }})::get(this, "", "vif", vif)) begin
            `uvm_fatal("NOVIF", {"Virtual interface must be set for: ", get_full_name(), ".vif"});
        end
    endfunction

    // Run Phase
    task run_phase(uvm_phase phase);
        forever begin
            seq_item_port.get_next_item(req);
            drive_item(req);
            seq_item_port.item_done();
        end
    endtask

    // Drive Item (User logic placeholder)
    virtual task drive_item({{ trans_type }} item);
        // TODO: Implement simple driving logic
        // Example:
        // @(posedge vif.CLK);
        // vif.ACT <= item.act;
    endtask

endclass : {{ agent.name }}_driver
//------------------------------------------------------------------------------
// Top module: {{ testbench_name }}_top
// Description: Testbench top with DUT and UVM harness
//------------------------------------------------------------------------------

module {{ testbench_name }}_top;

  `include "uvm_macros.svh"
  import uvm_pkg::*;

  import {{ dut_instance_name }}_params_pkg::*;

  import {{ dut_instance_name }}_test_pkg::*;

  // Clock and reset signals
  logic {{ clock.name }};
  logic {{ reset.name }};

  // Interface instances — one per declared interface
  {% for iface in interfaces %}
  {{ iface.name }} {{ iface.name }}_inst (
    .{{ clock.name }}({{ clock.name }}),
    .{{ reset.name }}({{ reset.name }})
  );
  {% endfor %}

  // DUT instance — ports wired to their respective interface instances
  {{ dut_entity_name }} dut (
    .{{ clock.name }}({{ clock.name }}),
    .{{ reset.name }}({{ reset.name }}),
    {% for iface, port in all_ports %}
    .{{ port.name }}({{ iface.name }}_inst.{{ port.name }}){{ "," if not loop.last }}
    {% endfor %}
  );

  // Clock generation
  initial begin
    {{ clock.name }} = 0;
    forever #5 {{ clock.name }} = ~{{ clock.name }};
  end

  // Reset generation (active {{ reset.active_level }})
  initial begin
    {{ reset.name }} = {% if reset.active_level == 'high' %}1{% else %}0{% endif %};
    #20;
    {{ reset.name }} = {% if reset.active_level == 'high' %}0{% else %}1{% endif %};
  end

  // UVM test start
  initial begin
    {% for iface in interfaces %}
    uvm_resource_db #(virtual {{ iface.name }})::set("*", "{{ iface.name }}", {{ iface.name }}_inst);
    {% endfor %}
    run_test();
  end

endmodule

//------------------------------------------------------------------------------
// Environment: {{ env_name }}
// Description: UVM Environment – instantiates agents, scoreboard and connects
//              analysis ports via TLM exports.
//------------------------------------------------------------------------------

class {{ env_name }} extends uvm_env;
    `uvm_component_utils({{ env_name }})

    //--------------------------------------------------------------------------
    // Agent instances
    //--------------------------------------------------------------------------
    {% for agent in agents %}
    {{ agent.name }}_agent {{ agent.name }};   // {{ agent.active.value }} agent
    {% endfor %}

    //--------------------------------------------------------------------------
    // Scoreboard
    //--------------------------------------------------------------------------
    {% if scoreboard %}
    {{ scoreboard.name }} m_scoreboard;
    {% endif %}

    //--------------------------------------------------------------------------
    // Virtual interface handle
    //--------------------------------------------------------------------------
    {% if if_name %}
    virtual {{ if_name }} m_vif;
    {% endif %}

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name = "{{ env_name }}", uvm_component parent = null);
        super.new(name, parent);
    endfunction : new

    //--------------------------------------------------------------------------
    // Build Phase – construct all sub-components
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);

        // Retrieve virtual interface from resource_db
        {% if if_name %}
        begin
            uvm_resource #(virtual {{ if_name }}) vif_res;
            if (!uvm_resource_db #(virtual {{ if_name }})::read_by_name(
                    get_full_name(), "{{ if_name }}", vif_res))
                `uvm_fatal(get_type_name(), "Failed to get virtual interface '{{ if_name }}' from resource_db")
            m_vif = vif_res.read(this);
        end
        {% endif %}

        // Construct agents
        {% for agent in agents %}
        {{ agent.name }} = {{ agent.name }}_agent::type_id::create("{{ agent.name }}", this);
        {% endfor %}

        // Construct scoreboard
        {% if scoreboard %}
        m_scoreboard = {{ scoreboard.name }}::type_id::create("m_scoreboard", this);
        {% endif %}

    endfunction : build_phase

    //--------------------------------------------------------------------------
    // Connect Phase – wire analysis ports to scoreboard exports
    //--------------------------------------------------------------------------
    function void connect_phase(uvm_phase phase);
        super.connect_phase(phase);

        // Propagate virtual interface down to agents via resource_db
        {% if if_name %}
        {% for agent in agents %}
        uvm_resource_db #(virtual {{ if_name }})::set(
            "{{ if_name }}", "{{ if_name }}", m_vif, this);
        {% endfor %}
        {% endif %}

        // Connect monitor analysis ports to scoreboard exports
        {% if scoreboard %}
        {% for agent in agents %}
        {% if agent.has_monitor %}
        {{ agent.name }}.m_monitor.ap.connect(m_scoreboard.{{ agent.name }}_export);
        {% endif %}
        {% endfor %}
        {% endif %}

    endfunction : connect_phase

    //--------------------------------------------------------------------------
    // Start of Simulation Phase – print topology
    //--------------------------------------------------------------------------
    function void start_of_simulation_phase(uvm_phase phase);
        super.start_of_simulation_phase(phase);
        `uvm_info(get_type_name(), $sformatf("Environment '%s' created.", get_full_name()), UVM_LOW)
        uvm_top.print_topology();
    endfunction : start_of_simulation_phase

endclass : {{ env_name }}

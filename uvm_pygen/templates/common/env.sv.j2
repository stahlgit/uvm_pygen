//------------------------------------------------------------------------------
// Environment: {{ env_name }}
// Description: UVM Environment – instantiates agents, scoreboard and connects
//              analysis ports via TLM exports.
//------------------------------------------------------------------------------

class {{ env_name }} extends uvm_env;
    `uvm_component_utils({{ env_name }})

    //--------------------------------------------------------------------------
    // Agent instances
    //--------------------------------------------------------------------------
    {% for agent in agents %}
    {{ agent.name }} m_{{ agent.name }};   // {{ agent.mode.value }} agent
    {% endfor %}

    //--------------------------------------------------------------------------
    // Scoreboard
    //--------------------------------------------------------------------------
    {% if reference_model %}
    {{ reference_model }} m_refmodel;
    {% endif %}

    {% if scoreboard %}
    {{ scoreboard }} m_scoreboard;
    {% endif %}

    //--------------------------------------------------------------------------
    // Virtual interface handle (one per instance)
    //--------------------------------------------------------------------------
    {% for iface in interfaces %}
    virtual {{ iface.name }} m_{{ iface.name }};
    {% endfor %}

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name = "{{ env_name }}", uvm_component parent = null);
        super.new(name, parent);
    endfunction : new

    //--------------------------------------------------------------------------
    // Build Phase – construct all sub-components
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);

        // Retrieve virtual interfaces from resource_db — one per declared interface.
        // top.sv sets each as: uvm_resource_db #(virtual <if_name>)::set("*", "<if_name>", <if_name>_inst)
        {% for iface in interfaces %}
        begin
            uvm_resource #(virtual {{ iface.name }}) vif_res_{{ iface.name }};
            vif_res_{{ iface.name }} = uvm_resource_db #(virtual {{ iface.name }})::get_by_name("*", "{{ iface.name }}", 0);
            if (vif_res_{{ iface.name }} == null)
                `uvm_fatal(get_type_name(), "Failed to get virtual interface '{{ iface.name }}' from resource_db")
            m_{{ iface.name }} = vif_res_{{ iface.name }}.read(this);
        end
        {% endfor %}

        // Construct reference model
        {% if reference_model %}
        m_refmodel = {{ reference_model }}::type_id::create("m_refmodel", this);
        {% endif %}

        // Construct scoreboard
        {% if scoreboard %}
        m_scoreboard = {{ scoreboard }}::type_id::create("m_scoreboard", this);
        {% endif %}

        // Construct agents
        {% for agent in agents %}
        m_{{ agent.name }} = {{ agent.name }}::type_id::create("m_{{ agent.name }}", this);
        {% endfor %}

    endfunction : build_phase

    //--------------------------------------------------------------------------
    // Connect Phase – wire analysis ports to scoreboard exports
    //--------------------------------------------------------------------------
    function void connect_phase(uvm_phase phase);
        super.connect_phase(phase);

        {% if reference_model_obj and reference_model_obj.connections %}
        {% for conn in reference_model_obj.connections %}
        {{ conn.from_sv }}.{{ conn.from_port }}.connect({{ conn.to_sv }}.{{ conn.to_port }});
        {% endfor %}
        {% elif reference_model_obj and not reference_model_obj.connections %}
        // WARNING: No connections defined for reference model.
        // Add 'connects:' entries to your config, or wire manually here.
        {% endif %}

    endfunction : connect_phase

    //--------------------------------------------------------------------------
    // Start of Simulation Phase – print topology
    //--------------------------------------------------------------------------
    function void start_of_simulation_phase(uvm_phase phase);
        super.start_of_simulation_phase(phase);
        `uvm_info(get_type_name(), $sformatf("Environment '%s' created.", get_full_name()), UVM_LOW)
        uvm_top.print_topology();
    endfunction : start_of_simulation_phase

endclass : {{ env_name }}

//------------------------------------------------------------------------------
// Environment: {{ env_name }}
// Description: UVM Environment – instantiates agents, scoreboard and connects
//              analysis ports via TLM exports.
//------------------------------------------------------------------------------

class {{ env_name }} extends uvm_env;
    `uvm_component_utils({{ env_name }})

    //--------------------------------------------------------------------------
    // Agent instances
    //--------------------------------------------------------------------------
    {% for agent in agents %}
    {{ agent.name }} m_{{ agent.name }};   // {{ agent.mode.value }} agent
    {% endfor %}

    //--------------------------------------------------------------------------
    // Scoreboard
    //--------------------------------------------------------------------------
    {% if reference_model %}
    {{ reference_model }} m_refmodel;
    {% endif %}

    {% if scoreboard %}
    {{ scoreboard }} m_scoreboard;
    {% endif %}

    //--------------------------------------------------------------------------
    // Virtual interface handle
    //--------------------------------------------------------------------------
    {% if if_name %}
    virtual {{ if_name }} m_vif;
    {% endif %}

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name = "{{ env_name }}", uvm_component parent = null);
        super.new(name, parent);
    endfunction : new

    //--------------------------------------------------------------------------
    // Build Phase – construct all sub-components
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);

        // Retrieve virtual interface from resource_db.
        // top.sv sets it as: uvm_resource_db #(virtual {{ if_name }})::set("*", "vif", vif)
        // Two-step get_by_name + .read() used for UVM 1.1d / Questa compatibility —
        // read_by_name has a type-resolution bug with virtual interfaces.
        {% if if_name %}
        begin
            uvm_resource #(virtual {{ if_name }}) vif_res;
            vif_res = uvm_resource_db #(virtual {{ if_name }})::get_by_name("*", "vif", 0);
            if (vif_res == null)
                `uvm_fatal(get_type_name(), "Failed to get virtual interface '{{ if_name }}' from resource_db")
            m_vif = vif_res.read(this);
        end
        {% endif %}

        // Construct reference model
        {% if reference_model %}
        m_refmodel = {{ reference_model }}::type_id::create("m_refmodel", this);
        {% endif %}

        // Construct scoreboard
        {% if scoreboard %}
        m_scoreboard = {{ scoreboard }}::type_id::create("m_scoreboard", this);
        {% endif %}

        // Construct agents
        {% for agent in agents %}
        m_{{ agent.name }} = {{ agent.name }}::type_id::create("m_{{ agent.name }}", this);
        {% endfor %}

    endfunction : build_phase

    //--------------------------------------------------------------------------
    // Connect Phase – wire analysis ports to scoreboard exports
    //--------------------------------------------------------------------------
    function void connect_phase(uvm_phase phase);
        super.connect_phase(phase);

        // Connect monitor analysis ports to scoreboard exports
        {% if scoreboard %}
            {% for agent in agents %}
                {% if agent.has(ComponentType.DRIVER) %}
        m_{{ agent.name }}.m_driver.ap.connect(m_refmodel.analysis_export);
                {% endif %}
                {% if agent.has(ComponentType.MONITOR)%}
        m_{{agent.name}}.m_monitor.analysis_port.connect(m_scoreboard.actual_export);
                {% endif %}
            {% endfor %}
        {% endif %}
        
        m_refmodel.ap_expected.connect(m_scoreboard.expected_export);
    endfunction : connect_phase

    //--------------------------------------------------------------------------
    // Start of Simulation Phase – print topology
    //--------------------------------------------------------------------------
    function void start_of_simulation_phase(uvm_phase phase);
        super.start_of_simulation_phase(phase);
        `uvm_info(get_type_name(), $sformatf("Environment '%s' created.", get_full_name()), UVM_LOW)
        uvm_top.print_topology();
    endfunction : start_of_simulation_phase

endclass : {{ env_name }}

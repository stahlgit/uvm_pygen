//------------------------------------------------------------------------------
// Class: {{ agent.name }}_monitor
// Description: Monitor for {{ agent.name }}
//------------------------------------------------------------------------------

class {{ agent.name }}_monitor extends uvm_monitor;
    `uvm_component_utils({{ agent.name }}_monitor)

    //--------------------------------------------------------------------------
    // Virtual interface handle
    //--------------------------------------------------------------------------
    virtual {{ if_name }} vif;

    //--------------------------------------------------------------------------
    // Analysis port
    //--------------------------------------------------------------------------
    uvm_analysis_port #({{ trans_type }}) analysis_port;

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    //--------------------------------------------------------------------------
    // Build Phase – create analysis port, retrieve vif from resource_db
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        uvm_resource #(virtual {{ if_name }}) vif_res;
        super.build_phase(phase);

        analysis_port = new("analysis_port", this);

        vif_res = uvm_resource_db #(virtual {{ if_name }})::get_by_name("*", "vif", 0);
        if (vif_res == null)
            `uvm_fatal("NOVIF", {"Virtual interface not found in resource_db for: ", get_full_name()})
        vif = vif_res.read(this);
    endfunction

    //--------------------------------------------------------------------------
    // Run Phase – sample on every clock edge via cbm, broadcast to analysis port
    //--------------------------------------------------------------------------
    task run_phase(uvm_phase phase);
        {{ trans_type }} item;

        forever begin
            @(vif.cbm);
            item = {{ trans_type }}::type_id::create("item");
            vif.monitor(item);
            analysis_port.write(item);
        end
    endtask

endclass : {{ agent.name }}_monitor

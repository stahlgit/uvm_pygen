//------------------------------------------------------------------------------
// Interface: {{ if_model.name }}
// Description: Physical interface with Clocking Blocks and Methods
//------------------------------------------------------------------------------

interface {{ if_model.name }}(
    input logic {{ if_model.clock.name if if_model.clock else 'CLK' }},
    input logic {{ if_model.reset.name if if_model.reset else 'RST' }}
);

    import {{ package_name }}::*; 
    import {{ trans_pkg_name }}::*;
    import uvm_pkg::*;
    `include "uvm_macros.svh"

    //--------------------------------------------------------------------------
    // Signals
    //--------------------------------------------------------------------------
    {% for port in if_model.ports %}
    {{port.type}} {{port.width}} {{port.name}};  // {{port.description}}
    {% if port.enum_name%}
    {{port.enum_name}} {{port.name.lower()+"_e"}};
    {% endif %}
    {% endfor %}

    //--------------------------------------------------------------------------
    // Clocking Blocks
    //--------------------------------------------------------------------------
    
    // Driver Clocking Block (Synchronous Drive)
    clocking cb @(posedge {{ if_model.clock.name if if_model.clock else 'CLK' }});
        // default input #1step output #1step;
        {% for port in if_model.ports %}
        {% if port.is_clock or port.is_reset %}{% continue %}{% endif %}
        {% if port.direction == 'input' %}
        output {{ port.name }};
        {% if port.enum_name %}
        output {{ port.name.lower()+"_e"}};
        {% endif %}
        {% else %}
        input  {{ port.name }}; 
        {% endif %}
        {% endfor %}
    endclocking

    // Monitor Clocking Block (Passive Sampling)
    clocking cbm @(posedge {{ if_model.clock.name if if_model.clock else 'CLK' }});
        {% for port in if_model.ports %}
        {% if port.is_clock or port.is_reset %}{% continue %}{% endif %}
        input {{ port.name }}; 
        {% endfor %}
    endclocking

    //--------------------------------------------------------------------------
    // Methods
    //--------------------------------------------------------------------------

    // Drive Task: Pushes transaction fields to interface
    task automatic drive({{ trans_type }} t);
        // Assign transaction variables to clocking block outputs
        {% for var in trans.variables %}
        {% for port in if_model.ports if port.direction == 'input' %}
        {% if var.name|upper == port.name|upper %}
        cb.{{ port.name }} <= t.{{ var.name }};
        {% if port.enum_name %}
        cb.{{ port.name.lower()+"_e" }} <= t.{{ var.name }};
        {% endif %}
        {% endif %}
        {% endfor %}
        {% endfor %}
    endtask

    // Monitor Task: Captures interface signals into transaction
    task automatic monitor({{ trans_type }} t);
        {% for var in trans.variables %}
        {% for port in if_model.ports %}
        {% if var.name|upper == port.name|upper %}
        {% if port.enum_name %}
        $cast(t.{{ var.name }}, int'(cbm.{{ port.name }})); 
        {% else %}
        t.{{ var.name }} = cbm.{{ port.name }};
        {% endif %}
        {% endif %}
        {% endfor %}
        {% endfor %}
    endtask

    // Utility: Wait for Clock
    task automatic wait_for_clock(int n = 1);
        repeat (n) @(cbm);
    endtask

    // Utility: Wait for Reset
    task automatic wait_for_reset();
        wait({{ if_model.reset.name if if_model.reset else 'RST' }} === {{ '0' if if_model.reset.active_low else '1' }});
    endtask

endinterface : {{ if_model.name }}
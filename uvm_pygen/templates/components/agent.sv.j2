//------------------------------------------------------------------------------
// Class: {{ agent.name }}
// Description: Agent container for {{ agent.name }}
// Mode: {% if agent.mode.value == "active" %}Active{% else %}Passive{% endif %}
//------------------------------------------------------------------------------

class {{ agent.name }} extends uvm_agent;
    `uvm_component_utils({{ agent.name }})

    //--------------------------------------------------------------------------
    // Component handles
    //--------------------------------------------------------------------------
    {% for part in agent.parts %}
    {{ agent.name }}_{{ part }} m_{{ part }};
    {% endfor %}

    //--------------------------------------------------------------------------
    // Analysis Port (pass-through from monitor)
    //--------------------------------------------------------------------------
    uvm_analysis_port #({{ trans_type }}) analysis_port;

    //--------------------------------------------------------------------------
    // Constructor
    //--------------------------------------------------------------------------
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    //--------------------------------------------------------------------------
    // Build Phase – construct sub-components
    //--------------------------------------------------------------------------
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);

        {% for part in agent.parts %}
        m_{{ part }} = {{ agent.name }}_{{ part }}::type_id::create("m_{{ part }}", this);
        {% endfor %}
    endfunction

    //--------------------------------------------------------------------------
    // Connect Phase – wire sequencer→driver and expose analysis port
    //--------------------------------------------------------------------------
    function void connect_phase(uvm_phase phase);
        super.connect_phase(phase);

        // Expose monitor analysis port at agent level
        analysis_port = m_monitor.analysis_port;

        {% if agent.mode.value == "active" %}
        // Connect driver ↔ sequencer TLM path
        m_driver.seq_item_port.connect(m_sequencer.seq_item_export);
        {% endif %}
    endfunction

endclass : {{ agent.name }}

//------------------------------------------------------------------------------
// Class: base_sequence
// Description: Base sequence for all test sequences
//------------------------------------------------------------------------------

class base_sequence extends uvm_sequence #({{ trans_type }});

    `uvm_object_utils(base_sequence)

    typedef {{ trans_type }} seq_item_t;

    {% for port in ports %}
    {% if port.direction == "input" and not port.is_clock and not port.is_reset %}
    {% if port.enum_name %}
    rand {{ port.enum_name }} default_{{ port.name.lower() }};
    {% else %}
    rand {{ port.type }} {{ port.width }} default_{{ port.name.lower() }};
    {% endif %}
    {% endif %}
    {% endfor %}

    function new(string name = "base_sequence");
        super.new(name);
    endfunction

    // NOTE: If your derived sequence needs direct sequencer access (e.g. config objects),
    // add to the derived class:
    //   `uvm_declare_p_sequencer(<agent_name>_sequencer)
    // and import the agent package in the sequence pkg.


    task body();
        req = seq_item_t::type_id::create("req");

        start_item(req);

        if (!req.randomize() with {
            {% for port in ports %}
            {% if port.direction == "input" and not port.is_clock and not port.is_reset %}
            {{ port.name.lower() }} == local::default_{{ port.name.lower() }};
            {% endif %}
            {% endfor %}
        }) begin
            `uvm_error("RANDOMIZE_FAIL", "Failed to randomize the transaction")
        end

        finish_item(req);
    endtask

endclass : base_sequence

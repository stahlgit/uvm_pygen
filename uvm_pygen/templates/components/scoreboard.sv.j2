//------------------------------------------------------------------------------
// Class: {{ scoreboard_name }}
// Description: Compares expected (from reference model) vs actual (from DUT monitor).
//              Raises uvm_error on mismatch.
//------------------------------------------------------------------------------

{% for export in scoreboard.exports %}
`uvm_analysis_imp_decl({{ export.imp_suffix }})
{% endfor %}

class {{ scoreboard_name }} extends uvm_scoreboard;
    `uvm_component_utils({{ scoreboard_name }})

    // Analysis exports
    {% for export in scoreboard.exports %}
    uvm_analysis_imp{{ export.imp_suffix }} #({{ export.transaction_type }}, {{ scoreboard_name }}) {{ export.port_name }};
    {% endfor %}

    // Internal queues (keyed by role)
    local {{ trans_type }} actual_q[$];
    local {{ trans_type }} expected_q[$];

    // Constructor
    function new(string name, uvm_component parent);
        super.new(name, parent);
    endfunction

    // Build phase – create exports
    function void build_phase(uvm_phase phase);
        super.build_phase(phase);
        {% for export in scoreboard.exports %}
        {{ export.port_name }} = new("{{ export.port_name }}", this);
        {% endfor %}
    endfunction

    // Write methods – one per export
    {% for export in scoreboard.exports %}
    function void write{{ export.imp_suffix }}({{ export.transaction_type }} t);
        {% if export.role == "actual" %}
        actual_q.push_back(t);
        {% else %}
        expected_q.push_back(t);
        {% endif %}
        check();
    endfunction

    {% endfor %}

    // Local check method – called after each push
    local function void check();
        {{ trans_type }} exp;
        {{ trans_type }} act;

        if (expected_q.size() == 0 || actual_q.size() == 0) return;

        exp = expected_q.pop_front();
        act = actual_q.pop_front();

        // Compare output fields
        if ({% set out_vars = trans.variables | selectattr("direction.value", "equalto", "output") | list %}
            {% for var in out_vars %}
            act.{{ var.name }} != exp.{{ var.name }}{% if not loop.last %} ||{% endif %}

            {% endfor %}
            ) begin
            `uvm_error(get_type_name(), $sformatf("Mismatch:\n  act=%p\n  exp=%p", act, exp))
        end else begin
            `uvm_info(get_type_name(), "Match!", UVM_HIGH)
        end
    endfunction

endclass
